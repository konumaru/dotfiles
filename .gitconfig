[user]
    name = konumaru
    email = konumaru1022@gmail.com

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[alias]
    ch = checkout
    br = branch
    a = add -A
    c = commit -m
    s = status
	copilot-commit = !git diff --staged | copilot -p 'ステージ済みの git diff を読み、Japanese Conventional Commits 形式の件名を 1 行だけ出力してください。形式は <type>: <summary> または <type>(<scope>): <summary>。type は feat, fix, refactor, docs, test, chore, ci, build, perf, style から最適なものを選ぶ。summary は自然な日本語で、具体的かつ簡潔に、可能なら 60 文字以内。scope は明確な場合のみ付ける。説明、引用符、コードブロック、箇条書き、前置き、後書き、改行は不要。出力は件名 1 行のプレーンテキストのみ。' | tr -d '\\n' | git commit -m \"$(cat)\"

[init]
    defaultBranc = main
    defaultBranch = main

[ghq]
    root = ~/Documents/repositories

[delta]
    line-numbers = true
    syntax-theme = Monokai Extended

[user]
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMJP6w1/wIkhxte3pfewwnvlheAuUGkxUdRczP5j4Ad4

[gpg]
    format = ssh

[gpg "ssh"]
    program = "/mnt/c/Program Files/1Password/app/8/op-ssh-sign-wsl"

[commit]
    gpgsign = true
